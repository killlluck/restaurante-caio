<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Restaurante do Caio | Login</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', sans-serif;
        }

        body {
            height: 100vh;
            background: linear-gradient(135deg, #14001a, #2b0033, #000000);
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .container {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(20px);
            border-radius: 20px;
            width: 400px;
            max-width: 90%;
            padding: 40px;
            text-align: center;
            color: white;
            box-shadow: 0 0 40px rgba(199, 125, 255, 0.3);
            border: 1px solid rgba(255,255,255,0.1);
        }

        /* LOGO */
        .logo {
            width: 90px;
            margin-bottom: 15px;
        }

        h1 {
            color: #c77dff;
            margin-bottom: 5px;
        }

        .subtitle {
            font-size: 14px;
            color: #aaa;
            margin-bottom: 25px;
        }

        /* INPUTS */
        .input-group {
            position: relative;
            margin-bottom: 20px;
        }

        .input-group input {
            width: 100%;
            padding: 12px;
            background: transparent;
            border: none;
            border-bottom: 2px solid #555;
            color: white;
            outline: none;
        }

        .input-group label {
            position: absolute;
            left: 0;
            top: 12px;
            color: #888;
            transition: 0.3s;
        }

        .input-group input:focus + label,
        .input-group input:valid + label {
            top: -10px;
            font-size: 12px;
            color: #c77dff;
        }

        /* BOTÃO */
        button {
            width: 100%;
            padding: 12px;
            background: linear-gradient(90deg, #7209b7, #c77dff);
            border: none;
            border-radius: 8px;
            color: white;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(199, 125, 255, 0.4);
        }

        /* LINKS */
        .extras {
            margin-top: 15px;
            font-size: 13px;
        }

        .extras a {
            color: #c77dff;
            text-decoration: none;
        }

        .extras a:hover {
            text-decoration: underline;
        }

        /* RODAPÉ */
        .footer {
            margin-top: 25px;
            font-size: 12px;
            color: #777;
        }

        .footer strong {
            color: #c77dff;
        }

    </style>
</head>

<body>

<div class="container">

    <!-- LOGO -->
    <img src="/logo.png" alt="Logo Restaurante do Caio" class="logo">

    <!-- TÍTULO -->
    <h1>Restaurante do Caio</h1>
    <p class="subtitle">Sabor que conquista todos os dias 🍽️</p>

    <!-- FORM -->
    <form action="/login" method="POST">

        <div class="input-group">
            <input type="text" name="username" required>
            <label>Usuário</label>
        </div>

        <div class="input-group">
            <input type="password" name="password" required>
            <label>Senha</label>
        </div>

        <button type="submit">Entrar</button>

    </form>

    <!-- LINKS -->
    <div class="extras">
        <p><a href="#">Esqueceu a senha?</a></p>
        <p>Não tem conta? <a href="#">Cadastre-se</a></p>
    </div>

    <!-- RODAPÉ -->
    <div class="footer">
        © 2026 <strong>Restaurante do Caio</strong><br>
        Sistema interno de pedidos e gestão
    </div>

</div>

</body>
</html>
