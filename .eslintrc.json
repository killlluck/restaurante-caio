- name: Criar configuração temporária do ESLint
  run: |
    cat > .eslintrc.json <<'EOF'
    {
      "env": {
        "node": true,
        "es2021": true
      },
      "extends": "eslint:recommended",
      "parserOptions": {
        "ecmaVersion": 12,
        "sourceType": "commonjs"
      },
      "rules": {
        "no-unused-vars": "warn",
        "no-undef": "error"
      },
      "parserOptions": {
  "ecmaVersion": 2021,
  "sourceType": "module"
}
    }
    EOF
